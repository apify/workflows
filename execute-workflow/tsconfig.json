{
  "extends": "@apify/tsconfig",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noImplicitAny": true,
    "importHelpers": false,
    "noEmitHelpers": false,
    "skipLibCheck": true,
    "strict": true,
    "erasableSyntaxOnly": true,
    "declaration": false,
    "declarationMap": false,
    "types": ["node"]
  },
  "exclude": ["node_modules"]
}
