{
  "extends": "@apify/tsconfig",
  "compilerOptions": {
    "module": "ES2022",
    "noImplicitAny": true,
    "importHelpers": false,
    "noEmitHelpers": false,
    "module": "ES2022",
    "skipLibCheck": true,
    "baseUrl": ".",
    "strict": true,
    "erasableSyntaxOnly": true,
  },
  "exclude": ["node_modules"]
}
